{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Novoskill : exporter toutes les sources",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\tools\\export_novoskill_sources.ps1",
        "-ProjectRoot",
        "${workspaceFolder}",
        "-IncludeUntrackedSources"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Novoskill : lancer la prévisualisation locale",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}\\local_preview_novoskill_all.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": false
      }
    }
  ]
}
