    contents_all = form.get("contenus") or []

    duree_label = format_duration_hr(form.get("duree"))
    tarif_label = _pdf_money(form.get("tarif_mini"))

    # ------------------------------------------------------------------
    # Génération canvas
    # ------------------------------------------------------------------
    buff = BytesIO()
    c = pdf_canvas.Canvas(buff, pagesize=(PAGE_W, PAGE_H))

    # ==============================================================
