 }
+
+/* Fiche collaborateur dédiée — ajustements finaux onglet Identification */
+#modalCollaborateur .sb-collab-company-cell strong,
+#modalCollaborateur .sb-collab-projection-item strong,
+#modalCollaborateur .sb-collab-role-item strong{
+  font-size:var(--ns-text-sm, 0.8125rem);
+  line-height:var(--ns-leading-title, 1.25);
+}
+
+#modalCollaborateur .sb-collab-block--projection .sb-collab-block-title,
+#modalCollaborateur .sb-collab-comment-card .sb-collab-block-title{
+  flex-wrap:nowrap;
+}
+
+#modalCollaborateur .sb-collab-block--projection .sb-collab-block-title > span:nth-child(2),
+#modalCollaborateur .sb-collab-comment-card .sb-collab-block-title > span:nth-child(2){
+  white-space:nowrap;
+}
+
+#modalCollaborateur .sb-collab-block--company > .sb-collab-block-title > .sb-collab-overview-event__icon{
+  color:var(--sb-warning);
+  background:var(--ns-warning-bg, #fffbeb);
+}
+
+#modalCollaborateur .sb-collab-block--projection > .sb-collab-block-title > .sb-collab-overview-event__icon{
+  color:var(--ns-success-text, #166534);
+  background:var(--ns-success-bg, #f0fdf4);
+}
+
+#modalCollaborateur .sb-collab-block--roles > .sb-collab-block-title > .sb-collab-overview-event__icon{
+  color:var(--accent);
+  background:color-mix(in srgb, var(--accent) 8%, #ffffff);
+}
+
+#modalCollaborateur .sb-collab-comment-card > .sb-collab-block-title > .sb-collab-overview-event__icon{
+  color:var(--sb-candidat);
+  background:color-mix(in srgb, var(--sb-candidat) 8%, #ffffff);
+}
+
+#modalCollaborateur .sb-collab-role-item:nth-child(1) .sb-collab-summary-icon{
+  color:var(--sb-manager);
+  background:color-mix(in srgb, var(--sb-manager) 8%, #ffffff);
+}
+
+#modalCollaborateur .sb-collab-role-item:nth-child(2) .sb-collab-summary-icon{
+  color:var(--sb-badge-formateur-border);
+  background:color-mix(in srgb, var(--sb-badge-formateur-border) 8%, #ffffff);
+}
