+  function render(){const o=state.overview||{},c=o.current; if(!c){$('peCurrentSub').textContent='Aucun entretien planifié.';$('peCurrentStatus').textContent='Aucun';$('peCurrentContent').innerHTML=P.itemEmpty('Aucun entretien à préparer actuellement.');$('peProcess').innerHTML='';}else{$('peCurrentSub').textContent=`${c.type_entretien} · ${P.fmtDate(c.date_prevue)}${c.manager?' · '+c.manager:''}`;$('peCurrentStatus').textContent=c.statut;$('peCurrentStatus').className=`ns-badge ns-badge-status ns-badge-status--${statusKind(c.statut)}`;$('peCurrentContent').innerHTML=`<div class="pe-current-summary"><div><strong>${P.escapeHtml(c.type_entretien)}</strong><span>${P.fmtDate(c.date_prevue)}</span></div><div class="sb-actions"><button class="sb-btn sb-btn--accent" id="pePrepareOpen">${c.preparation_people?.statut==='non_commencee'?'Préparer':'Reprendre la préparation'}</button><button class="sb-btn sb-btn--soft" id="peCurrentDetail">Consulter</button></div></div>`;$('peProcess').innerHTML=processHtml(c);$('pePrepareOpen').onclick=()=>loadDetail(c.id_entretien,true);$('peCurrentDetail').onclick=()=>loadDetail(c.id_entretien,false)}
+    const actions=[];if(c){const pa=c.plan_actions;if(Array.isArray(pa))pa.forEach(a=>actions.push({title:a.titre||a.action||'Action',sub:[a.statut,a.echeance].filter(Boolean).join(' · ')}));else if(pa&&typeof pa==='object')Object.values(pa).forEach(a=>{if(a&&typeof a==='object')actions.push({title:a.titre||a.action||'Action',sub:[a.statut,a.echeance].filter(Boolean).join(' · ')})})}$('peActions').innerHTML=rows(actions,'Aucune action active issue de vos entretiens.');$('peRequests').innerHTML=rows((o.requests||[]).map(r=>({objet:r.objet,statut:r.statut})),'Aucune demande en cours.');renderHistory(o.history||[])}
+  function renderHistory(list){const fy=$('peFilterYear').value,ft=$('peFilterType').value,fs=$('peFilterStatus').value;const filtered=list.filter(r=>(!fy||String(r.date_prevue||r.date_realisee||'').startsWith(fy))&&(!ft||r.type_entretien===ft)&&(!fs||r.statut===fs));$('peHistory').innerHTML=filtered.length?filtered.map(r=>`<div class="pp-list-row"><div><div class="pp-row-title">${P.escapeHtml(r.type_entretien)}</div><div class="pp-row-sub">${P.fmtDate(r.date_realisee||r.date_prevue)} · ${P.escapeHtml(r.manager||'Interlocuteur non renseigné')}</div></div><div class="sb-actions"><span class="ns-badge ns-badge-status ns-badge-status--${statusKind(r.statut)}">${P.escapeHtml(r.statut)}</span><button class="sb-icon-btn" data-detail="${P.escapeHtml(r.id_entretien)}" aria-label="Consulter"><svg viewBox="0 0 24 24" class="ns-icon-use"><use href="/novoskill_icons.svg#ns-icon-eye"></use></svg></button></div></div>`).join(''):P.itemEmpty('Aucun entretien ne correspond aux filtres.');$('peHistory').querySelectorAll('[data-detail]').forEach(b=>b.onclick=()=>loadDetail(b.dataset.detail,false))}
+  function fillFilters(list){const years=[...new Set(list.map(r=>String(r.date_prevue||r.date_realisee||'').slice(0,4)).filter(Boolean))].sort().reverse(),types=[...new Set(list.map(r=>r.type_entretien).filter(Boolean))],statuses=[...new Set(list.map(r=>r.statut).filter(Boolean))];years.forEach(v=>$('peFilterYear').insertAdjacentHTML('beforeend',`<option>${P.escapeHtml(v)}</option>`));types.forEach(v=>$('peFilterType').insertAdjacentHTML('beforeend',`<option>${P.escapeHtml(v)}</option>`));statuses.forEach(v=>$('peFilterStatus').insertAdjacentHTML('beforeend',`<option>${P.escapeHtml(v)}</option>`))}
