re>${P.escapeHtml(JSON.stringify(d.entretien.synthese||{},null,2))}</pre></section><section><div class="card-title">Objectifs</div><pre>${P.escapeHtml(JSON.stringify(d.entretien.objectifs||{},null,2))}</pre></section><section><div class="card-title">Plan d’actions</div><pre>${P.escapeHtml(JSON.stringify(d.entretien.plan_actions||{},null,2))}</pre></section><section><div class="card-title">Documents</div><div class="sb-actions">${docs||'Aucun document disponible.'}</div></section></div>`;open('peDetailModal');$('peDetailBody').querySelectorAll('[data-doc]').forEach(b=>b.onclick=async()=>{const w=window.open('','_blank');try{await(window.__peopleAuthReady||Promise.resolve());const s=await window.PortalAuthCommon.getSession();const r=await fetch(`${P.API_BASE}/people/entretiens/${encodeURIComponent(id)}/${encodeURIComponent(idEnt)}/documents/${encodeURIComponent(b.dataset.doc)}`,{headers:{Authorization:`Bearer ${s.access_token}`}});if(!r.ok)throw new Error('Document indisponible');const blob=await r.blob();w.location=URL.createObjectURL(blob)}catch(e){w.close();$('peMessage').textContent=e.message}})}}
+  async function savePrep(transmit){const d=state.currentDetail;if(!d)return;const id=P.getEffectifId(),eid=d.entretien.id_entretien;$('pePrepMessage').textContent='Enregistrement…';const r=await P.api(`/people/entretiens/${encodeURIComponent(id)}/${encodeURIComponent(eid)}/preparation`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(prepPayload())}).catch(e=>({error:e.message}));if(r.error){$('pePrepMessage').textContent=r.error;return}if(transmit){const t=await P.api(`/people/entretiens/${encodeURIComponent(id)}/${encodeURIComponent(eid)}/preparation/transmit`,{method:'POST'}).catch(e=>({error:e.message}));if(t.error){$('pePrepMessage').textContent=t.error;return}}close('pePrepModal');load()}
+  async function sendRequest(){const id=P.getEffectifId(),payload={destinataire:$('peRequestTarget').value,motif:$('peRequestReason').value,objet:$('peRequestObject').value,description:$('peRequestDescription').value};const r=await P.api(`/people/entretiens/${encodeURIComponent(id)}/request`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)}).catch(e=>({error:e.message}));if(r.error){$('peRequestMessage').textContent=r.error;return}close('peRequestModal');load()}
+  window.addEventListener('DOMContentLoaded',()=>{load();$('peRequestOpen').onclick=()=>open('peRequestModal');$('peRequestClose').onclick=$('peRequestCancel').onclick=()=>close('peRequestModal');$('peRequestSave').onclick=sendRequest;$('pePrepClose').onclick=$('pePrepCancel').onclick=()=>close('pePrepModal');$('pePrepSave').onclick=()=>savePrep(false);$('pePrepTransmit').onclick=()=>savePrep(true);$('peDetailClose').onclick=()=>close('peDetailModal');['peFilterYear','peFilterType','peFilterStatus'].forEach(id=>$(id).onchange=()=>renderHistory(state.overview?.history||[]))});
+})();
