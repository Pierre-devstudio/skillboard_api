        FROM public.tbl_competence
        WHERE id_owner = %s
          AND id_comp = ANY(%s)
          AND COALESCE(masque, FALSE) = FALSE
        """,
        (oid, clean_ids),
    )

    valid = {str(r.get("id_comp") or "").strip() for r in (cur.fetchall() or [])}
    return [cid for cid in clean_ids if cid in valid]


