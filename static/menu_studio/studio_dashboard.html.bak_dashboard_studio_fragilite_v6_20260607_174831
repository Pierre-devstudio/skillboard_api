<section id="view-dashboard" class="studio-dash studio-dash-adaptive">
  <div class="sb-dashboard-logo-wrap studio-dashboard-logo-wrap">
    <img src="/Logo_NOVOSKILL.png" alt="Novoskill" class="sb-logo">
  </div>

  <div class="card sb-dashboard-hero studio-dash-hero">
    <div class="sb-dashboard-hero-main">
      <div class="card-title" id="studioDashWelcome">Bienvenue</div>
    </div>

    <div class="sb-dashboard-scope studio-dash-scope" aria-label="Filtres du dashboard">
      <div class="sb-dashboard-scope-field studio-dash-filter-field studio-dash-filter-field--service">
        <label for="studioDashService">Périmètre</label>
        <select id="studioDashService" class="sb-dashboard-service-select studio-dash-service-select">
          <option value="">Tous les services</option>
        </select>
      </div>

      <div class="sb-dashboard-crit-field studio-dash-filter-field studio-dash-filter-field--range">
        <label for="studioDashCriticite">Criticité minimale <strong id="studioDashCriticiteLabel">≥ 70</strong></label>
        <input id="studioDashCriticite" class="sb-dashboard-crit-range studio-dash-crit-range" type="range" min="0" max="100" step="5" value="70" aria-label="Criticité minimale">
      </div>

      <button type="button" class="sb-btn sb-btn--init studio-dash-refresh" id="studioDashRefresh">Actualiser</button>
    </div>
  </div>

  <div id="studioDashStatus" class="studio-dash-status">Chargement…</div>

  <div class="studio-dash-grid studio-dash-grid--row3">
    <article class="card studio-dash-card studio-dash-card--health">
      <div class="studio-dash-card-head studio-dash-card-head--inline">
        <h2>Santé de la structure</h2>
        <button type="button" class="studio-dash-help sb-dash-round-btn" data-help="health" aria-label="Explication santé de la structure">?</button>
      </div>
      <div class="sb-health-gauge-wrap studio-health-gauge-wrap">
        <svg id="studioDashHealthGauge" class="sb-health-gauge" viewBox="0 0 260 170" aria-label="Jauge santé de la structure"></svg>
        <div class="sb-health-pct" id="studioDashHealthPct">—%</div>
      </div>
      <div class="sb-health-status" id="studioDashHealthLabel">—</div>
    </article>

    <article class="card studio-dash-card">
      <div class="studio-dash-card-head studio-dash-card-head--inline">
        <h2>Demandes terrain</h2>
        <button type="button" class="studio-dash-help sb-dash-round-btn" data-help="demandes" aria-label="Explication demandes terrain">?</button>
      </div>
      <div class="studio-dash-kpi-line"><span>Ouvertes</span><strong id="studioDashDemandesOpen">0</strong></div>
      <div class="studio-dash-kpi-line"><span>Urgentes</span><strong id="studioDashDemandesUrgentes">0</strong></div>
      <div class="studio-dash-kpi-line"><span>Prises en charge</span><strong id="studioDashDemandesInProgress">0</strong></div>
    </article>

    <article class="card studio-dash-card">
      <div class="studio-dash-card-head studio-dash-card-head--inline">
        <h2>Entretiens à relancer</h2>
        <button type="button" class="studio-dash-help sb-dash-round-btn" data-help="entretiens" aria-label="Explication entretiens à relancer">?</button>
      </div>
      <div class="studio-dash-kpi-line"><span>À réaliser</span><strong id="studioDashEntretiensTodo">0</strong></div>
      <div class="studio-dash-kpi-line"><span>En cours</span><strong id="studioDashEntretiensProgress">0</strong></div>
      <div class="studio-dash-kpi-line"><span>À signer</span><strong id="studioDashEntretiensSign">0</strong></div>
    </article>
  </div>

  <div class="studio-dash-grid studio-dash-grid--row3">
    <article class="card studio-dash-card">
      <div class="studio-dash-card-head studio-dash-card-head--inline">
        <h2>Qualité des référentiels</h2>
        <button type="button" class="studio-dash-help sb-dash-round-btn" data-help="referentiel" aria-label="Explication qualité des référentiels">?</button>
      </div>
      <div class="studio-dash-kpi-line"><span>Postes sans compétence</span><strong id="studioDashPostesSansComp">0</strong></div>
      <div class="studio-dash-kpi-line"><span>Compétences sans domaine</span><strong id="studioDashCompSansDomaine">0</strong></div>
      <div class="studio-dash-kpi-line"><span>Collaborateurs sans poste</span><strong id="studioDashCollabSansPoste">0</strong></div>
    </article>

    <article class="card studio-dash-card">
      <div class="studio-dash-card-head studio-dash-card-head--inline">
        <h2>Capacité de transmission</h2>
        <button type="button" class="studio-dash-help sb-dash-round-btn" data-help="transmission" aria-label="Explication capacité de transmission">?</button>
      </div>
      <div class="studio-dash-ring" id="studioDashTransmissionRing"><span id="studioDashTransmissionPct">—</span></div>
    </article>

    <article class="card studio-dash-card">
      <div class="studio-dash-card-head studio-dash-card-head--inline">
        <h2>Fiabilité des données</h2>
        <button type="button" class="studio-dash-help sb-dash-round-btn" data-help="fiabilite" aria-label="Explication fiabilité des données">?</button>
      </div>
      <div class="studio-dash-signal" id="studioDashReliabilitySignal"></div>
      <div class="studio-dash-big-number studio-dash-big-number--sm" id="studioDashReliabilityPct">—</div>
    </article>
  </div>

  <div class="studio-dash-grid studio-dash-grid--full">
    <article class="card studio-dash-card studio-dash-card--large">
      <div class="studio-dash-card-head studio-dash-card-head--inline studio-dash-card-head--risk">
        <h2 id="studioDashRiskTitle">Indice de fragilité des services</h2>
        <div class="studio-dash-head-right">
          <div class="studio-dash-legend">
            <span><i class="studio-dot studio-dot--danger"></i><strong id="studioDashNbDanger">0</strong> en danger</span>
            <span><i class="studio-dot studio-dot--watch"></i><strong id="studioDashNbWatch">0</strong> à surveiller</span>
            <span><i class="studio-dot studio-dot--stable"></i><strong id="studioDashNbStable">0</strong> stables</span>
          </div>
          <button type="button" class="studio-dash-help sb-dash-round-btn" data-help="fragilite" aria-label="Explication indice de fragilité">?</button>
        </div>
      </div>
      <div class="studio-dash-risk-bars" id="studioDashRiskBars"></div>
    </article>
  </div>

  <div class="studio-dash-linked" id="studioDashLinkedSection" style="display:none;">
    <article class="card studio-dash-card studio-dash-card--large">
      <div class="studio-dash-card-head studio-dash-card-head--inline studio-dash-card-head--with-count">
        <h2>Sites / clients à surveiller</h2>
        <div class="studio-dash-head-right">
          <span class="studio-dash-count" id="studioDashLinkedCount">0</span>
          <button type="button" class="studio-dash-help sb-dash-round-btn" data-help="linked" aria-label="Explication sites et clients à surveiller">?</button>
        </div>
      </div>
      <div class="studio-dash-mini-list" id="studioDashLinkedStructureItems"></div>
    </article>
  </div>

  <div class="sb-modal studio-dash-modal" id="studioDashHelpModal" aria-hidden="true" style="display:none;">
    <div class="sb-modal-card studio-dash-modal-card" role="dialog" aria-modal="true" aria-labelledby="studioDashHelpTitle">
      <div class="sb-modal-head">
        <h3 id="studioDashHelpTitle">Indicateur</h3>
        <button type="button" class="sb-modal-x" id="studioDashHelpClose" aria-label="Fermer">×</button>
      </div>
      <div class="sb-modal-body">
        <p id="studioDashHelpBody"></p>
      </div>
    </div>
  </div>
</section>
