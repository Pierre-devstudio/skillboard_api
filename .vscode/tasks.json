{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Novoskill : exporter toutes les sources",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\tools\\export_novoskill_sources.ps1",
        "-ProjectRoot",
        "${workspaceFolder}",
        "-IncludeUntrackedSources"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
