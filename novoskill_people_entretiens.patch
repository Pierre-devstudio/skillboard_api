+(function(){
+  const P=window.PeoplePortal;if(!P)return;let state={overview:null,currentDetail:null};const $=id=>document.getElementById(id);
+  const open=id=>{const e=$(id);if(e)e.style.display='flex'};const close=id=>{const e=$(id);if(e)e.style.display='none'};
+  const statusKind=s=>/termin|réalis|valide|sign/i.test(s||'')?'success':/cours|prépar|plan/i.test(s||'')?'info':'neutral';
+  function rows(items,empty){return items?.length?items.map(x=>`<div class="pp-list-row"><div><div class="pp-row-title">${P.escapeHtml(x.title||x.objet||'-')}</div><div class="pp-row-sub">${P.escapeHtml(x.sub||x.statut||'')}</div></div>${x.action||''}</div>`).join(''):P.itemEmpty(empty)}
